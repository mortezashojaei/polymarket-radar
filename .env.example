TELEGRAM_BOT_TOKEN=123456:your-token
TELEGRAM_CHANNEL_ID=@your_channel
RUN_EVERY_MINUTES=10
MIN_LIQUIDITY=10000
MIN_VOLUME_24H=5000
MIN_ODDS_SWING=8
TOP_SIGNALS=15
CLEAR_ON_START=false
CLEAR_ON_START_LIMIT=200
DATABASE_PATH=./data/radar.db
POLYMARKET_EVENTS_URL=https://gamma-api.polymarket.com/events?closed=false&limit=200&active=true

# Radar v2 scoring/routing
SCORE_TIER_A=75
SCORE_TIER_B=55
MERGE_WINDOW_MINUTES=20
COOLDOWN_MINUTES=45
FLIP_LOOKBACK_HOURS=6
FLIP_PTS_THRESHOLD=8
REEMIT_SCORE_DELTA=15
MIN_WHALE_NOTIONAL=10000
MIN_FLOW_MULTIPLE=2.5
POST_TIER_B_IN_DIGEST=true

# Whale transaction polling
WHALE_POLL_ENABLED=true
WHALE_POLL_MINUTES=5
WHALE_SINGLE_TX_NOTIONAL=10000
WHALE_TX_WINDOW_MINUTES=10
WHALE_TX_MAX_PER_POLL=3
